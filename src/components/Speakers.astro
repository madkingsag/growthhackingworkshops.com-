---
import { speakers } from '../data/content';
---

<section id="speakers" class="py-16 md:py-24 bg-brand-light">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 uppercase">Who are the speakers</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-12">
      {speakers.map((speaker) => (
        <div class="text-center">
          <img
            src={speaker.photo}
            alt={speaker.name}
            class="w-36 h-36 md:w-44 md:h-44 rounded-full object-cover mx-auto mb-4 shadow-lg"
          />
          <p class="text-brand-orange text-xs uppercase tracking-widest mb-1">– MAD KINGS –</p>
          <p class="text-sm uppercase tracking-wider text-gray-500 mb-1">{speaker.role}</p>
          <p class="font-bold text-lg text-brand-dark">{speaker.name}</p>
          <a
            href={speaker.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-2 text-brand-blue hover:text-brand-orange transition-colors"
            aria-label={`${speaker.name} on LinkedIn`}
          >
            <svg class="w-5 h-5 inline" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
