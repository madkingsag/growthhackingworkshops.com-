---
import { hero } from '../data/content';
---

<section class="relative min-h-screen flex flex-col items-center justify-center text-center px-4 text-white overflow-hidden">
  <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/hero.jpg');"></div>
  <div class="absolute inset-0 bg-[#015284]/80"></div>
  <div class="relative z-10">
    <img src="/images/MK_Academy_Logo.svg" alt="MAD Kings Academy" class="w-[28rem] md:w-[42rem] mx-auto mb-8" />
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight max-w-4xl mb-6 mx-auto">
      Growth Hacking Workshop
    </h1>
    <p class="text-lg md:text-xl font-medium uppercase tracking-wide text-white/90 mb-4 max-w-3xl mx-auto">
      {hero.headline}
    </p>
    <p class="text-lg md:text-xl text-white/70 mb-10 max-w-2xl mx-auto">
      {hero.tagline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#why-attend"
        class="px-8 py-3 bg-brand-orange text-white font-bold uppercase tracking-wider rounded hover:bg-brand-orange/90 transition-colors"
      >
        Tell me more
      </a>
      <a
        href="#schedule"
        class="px-8 py-3 border-2 border-white text-white font-bold uppercase tracking-wider rounded hover:bg-white hover:text-brand-dark transition-colors"
      >
        See schedule
      </a>
    </div>
  </div>
</section>
