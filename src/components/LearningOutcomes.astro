---
import { learningOutcomes } from '../data/content';
---

<section class="py-16 md:py-24 bg-brand-light">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">What you will learn</h2>
    <ul class="space-y-5">
      {learningOutcomes.map((outcome) => (
        <li class="flex items-start gap-4 text-lg text-gray-700">
          <span class="text-brand-blue text-xl leading-none mt-1">&#10003;</span>
          <span>{outcome}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
