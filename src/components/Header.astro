---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm transition-transform duration-300 -translate-y-full">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href="#" class="flex items-center gap-3">
      <img src="/images/MK_Academy_Logo.svg" alt="MAD Kings Academy" class="h-10" />
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium uppercase tracking-wider text-brand-dark">
      <a href="#why-attend" class="hover:text-brand-orange transition-colors">Why Attend</a>
      <a href="#speakers" class="hover:text-brand-orange transition-colors">Speakers</a>
      <a href="#schedule" class="hover:text-brand-orange transition-colors">Schedule</a>
      <a href="#framework" class="hover:text-brand-orange transition-colors">Framework</a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  let lastScroll = 0;
  const heroHeight = window.innerHeight * 0.5;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > heroHeight) {
      header?.classList.remove('-translate-y-full');
    } else {
      header?.classList.add('-translate-y-full');
    }
    lastScroll = currentScroll;
  });
</script>
