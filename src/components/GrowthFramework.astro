---
import { growthFramework } from '../data/content';
---

<section id="framework" class="py-16 md:py-24 bg-brand-light">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-8">What is growth hacking anyway?</h2>
    <p class="text-gray-600 text-lg leading-relaxed max-w-4xl mx-auto text-center mb-20">
      {growthFramework.definition}
    </p>

    {/* AAARRR Framework */}
    <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
      <div>
        <img
          src={growthFramework.aaarrr.diagram}
          alt="AAARRR Framework Funnel"
          class="w-full max-w-md mx-auto"
        />
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-4 uppercase tracking-wider text-brand-orange">
          {growthFramework.aaarrr.title}
        </h3>
        <p class="text-gray-600 leading-relaxed">{growthFramework.aaarrr.description}</p>
      </div>
    </div>

    {/* Lean Marketing */}
    <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
      <div class="md:order-2">
        <img
          src={growthFramework.leanMarketing.diagram}
          alt="Lean Marketing Process"
          class="w-full max-w-md mx-auto"
        />
      </div>
      <div class="md:order-1">
        <h3 class="text-2xl font-bold mb-4 uppercase tracking-wider text-brand-orange">
          {growthFramework.leanMarketing.title}
        </h3>
        <p class="text-gray-600 leading-relaxed">{growthFramework.leanMarketing.description}</p>
      </div>
    </div>

    {/* Growth Skillset */}
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <img
          src={growthFramework.growthSkillset.diagram}
          alt="T-Shaped Growth Skillset"
          class="w-full max-w-md mx-auto"
        />
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-4 uppercase tracking-wider text-brand-orange">
          {growthFramework.growthSkillset.title}
        </h3>
        <p class="text-gray-600 leading-relaxed">{growthFramework.growthSkillset.description}</p>
      </div>
    </div>
  </div>
</section>
