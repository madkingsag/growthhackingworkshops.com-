---
import { audiences } from '../data/content';
---

<section class="py-16 md:py-24 bg-brand-light">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Who should attend</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {audiences.map((audience) => (
        <div class="bg-white rounded-lg p-8 text-center shadow-md border border-gray-100">
          <h3 class="text-xl font-bold mb-4 uppercase tracking-wider text-brand-blue">{audience.title}</h3>
          <p class="text-gray-600 leading-relaxed">{audience.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
